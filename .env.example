# Supabase Configuration
# 
# For LOCAL development (with docker-compose):
# VITE_SUPABASE_URL=http://localhost:5432
# VITE_SUPABASE_ANON_KEY=your-anon-key-here
# 
# For CLOUD deployment (using Supabase cloud):
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-cloud-anon-key
#

# Local Database Configuration (when using docker-compose)
VITE_DB_HOST=localhost
VITE_DB_PORT=5432
VITE_DB_USER=postgres
VITE_DB_PASSWORD=postgres
VITE_DB_NAME=postgres

# API Configuration
VITE_API_URL=http://localhost:3000/api

# Feature Flags
VITE_ENABLE_OFFLINE_MODE=true
